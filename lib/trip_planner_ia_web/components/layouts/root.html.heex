<!DOCTYPE html>
<html lang={@locale || "pt-BR"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="theme-color" content="#4f46e5" />
    <meta name="application-name" content="TripPlanner" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="TripPlanner" />
    <TripPlannerIaWeb.Seo.meta locale={@locale} page_title={assigns[:page_title]} />
    <.live_title default="TripPlanner" suffix=" · IA">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/images/icons/favicon-32x32.png"} />
    <link rel="icon" type="image/png" sizes="16x16" href={~p"/images/icons/favicon-16x16.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/images/icons/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/manifest.webmanifest"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-white text-slate-800 font-sans antialiased">
    {@inner_content}
  </body>
</html>
