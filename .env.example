# AI provider: gemini | nvidia-nim
AI_PROVIDER=gemini
AI_MODEL=

GEMINI_API_KEY=
NVIDIA_API_KEY=

# Local dev: priv/data/trip_planner_ia_dev.db (set in config/dev.exs)
# Prod Turso: libsql://your-db.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000
PHX_SERVER=true

# Trip generation: true = multi-step, false = single prompt
TRIP_PLANNER_MULTI_STEP=true